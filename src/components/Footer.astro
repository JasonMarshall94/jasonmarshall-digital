---
import Logo from "@/components/Logo.astro";

interface Props {
  startYear?: number;
  githubUrl?: string;
}
const { startYear = 2023, githubUrl = "https://github.com/JasonMarshall94" } =
  Astro.props;
const currentYear = new Date().getFullYear();
const ghLabel = githubUrl.replace(/^https?:\/\//, "");
---

<footer class="site-footer">
  <div class="container">
    <div class="footer-row">
      <a href="#top" class="footer-logo">
        <Logo size={36} />
      </a>
      <div class="footer-pitch">
        Building on the web since {startYear}.<br />
        <span class="footer-pitch-sub">Always open to interesting work.</span>
      </div>
      <a href="#contact" class="btn">Get in touch →</a>
    </div>

    <div class="footer-meta">
      <span
        >© {startYear}–{currentYear} Jason Marshall Digital · All rights reserved</span
      >
      <span class="hide-mobile"
        >Built with Astro & Tailwind · Hosted on the modern web</span
      >
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link footer-gh"
      >
        {ghLabel} ↗
      </a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: 3rem 0 2rem;
    margin-top: 2rem;
  }
  .footer-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 2rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    color: var(--color-text);
  }
  .footer-pitch {
    font-size: clamp(1.2rem, 2.4vw, 1.8rem);
    color: var(--color-text);
    letter-spacing: -0.01em;
    line-height: 1.2;
  }
  .footer-pitch-sub {
    color: var(--color-light-grey);
  }
  .footer-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.74rem;
    letter-spacing: 0.1em;
    color: var(--color-med-grey);
  }
  .footer-gh {
    color: var(--color-light-grey);
  }
  @media (max-width: 720px) {
    .footer-row {
      grid-template-columns: 1fr;
      text-align: center;
      justify-items: center;
    }
  }
</style>
