---
import SectionHeading from "@/ui/SectionHeading.astro";
import CopyChip from "@/ui/CopyChip.astro";
import ContactForm from "@/components/ContactForm.astro";
import data from "@/data/siteData.yaml";

interface Props {
  email?: string;
  phone?: string;
  endpoint?: string;
}
const {
  email = data.contactInfo.email,
  phone = data.contactInfo.phone,
  endpoint,
} = Astro.props;

const telHref = `tel:${phone.replace(/[^0-9+]/g, "")}`;
---

<section id="contact" class="border-border border-t py-32">
  <div class="container">
    <SectionHeading
      index="04"
      eyebrow="Contact / Start Here"
      title="Got a project? Let's talk."
      description="Booking projects for the next quarter. Reach out with a short brief or just say hi — I read every email."
    />

    <div
      class="grid grid-cols-[minmax(0,1fr)_minmax(0,1.4fr)] gap-6 max-[860px]:grid-cols-1"
    >
      <div class="flex flex-col gap-4">
        <CopyChip label="01 / Email" value={email} href={`mailto:${email}`} />
        <CopyChip label="02 / Phone" value={phone} href={telHref} />
        <div
          class="border-border bg-card text-accent border p-[1.6rem] text-[0.82rem] leading-[1.7]"
        >
          <div class="label mb-[0.8rem]">03 / Process</div>
          <ol class="text-accent m-0 pl-[1.2rem]">
            <li>Reply within 24h</li>
            <li>Free 30-min scoping call</li>
            <li>Fixed-price proposal in writing</li>
            <li>Kickoff once you sign</li>
          </ol>
        </div>
      </div>
      <ContactForm endpoint={endpoint} />
    </div>
  </div>
</section>
