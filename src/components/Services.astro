---
import SectionHeading from "@/ui/SectionHeading.astro";

const items = [
  {
    n: "01",
    title: "Design",
    tag: "Visual · Brand · UX",
    body: "Clean, intentional design built around how your customers actually move through a site. Every layout decision earns its place. No templates, no bloat.",
    bullets: [
      "Brand-aligned visual systems",
      "UX-first page layouts",
      "Design handoff & component docs",
    ],
  },
  {
    n: "02",
    title: "Development",
    tag: "WordPress · Astro · Next.js",
    body: "Custom or template builds on the right stack for the job. WordPress for sites clients need to edit, Astro or Next.js when performance and scale demand it.",
    bullets: [
      "Custom themes & block libraries",
      "CMS-driven page templates",
      "Full-stack apps & headless builds",
    ],
  },
  {
    n: "03",
    title: "SEO",
    tag: "Search · Performance · Content",
    body: "Visibility that compounds. Technical SEO baked into every build. Fast load times, clean markup, and content structure that search engines and humans both understand.",
    bullets: [
      "Technical audits & optimization",
      "Schema, metadata & Core Web Vitals",
      "Content strategy & keyword targeting",
    ],
  },
];
---

<section id="services" class="border-border border-t py-20 md:py-32">
  <div class="container">
    <SectionHeading
      index="02"
      eyebrow="Services / What I Do"
      title="The work, start to finish."
      description="Design, development, and SEO. Everything a small business needs to show up online and actually convert."
    />

    <div
      class="bg-border border-border grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-px border"
    >
      {
        items.map((it) => (
          <div
            data-service
            class="bg-card px-8 py-[2.4rem] transition-colors duration-200 hover:bg-white/[0.025]"
          >
            <div class="mb-[1.6rem] flex items-baseline justify-between">
              <span class="text-med-grey text-[0.72rem] tracking-[0.12em]">
                / {it.n}
              </span>
              <span class="label text-[0.66rem]">{it.tag}</span>
            </div>
            <h3 class="m-0 mb-4 text-[1.6rem] font-medium tracking-[-0.01em]">
              {it.title}
            </h3>
            <p class="text-accent m-0 text-[0.9rem] leading-[1.65]">
              {it.body}
            </p>
            <ul class="text-light-grey mt-[1.8rem] flex list-none flex-col gap-2 p-0 text-[0.82rem]">
              {it.bullets.map((b) => (
                <li class="flex gap-[0.7rem]">
                  <span class="text-med-grey">→</span> {b}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.matchMedia().add("(prefers-reduced-motion: no-preference)", () => {
    const serviceItems = document.querySelectorAll("[data-service]");
    if (serviceItems.length) {
      gsap.from(serviceItems, {
        opacity: 0,
        y: 30,
        duration: 0.8,
        stagger: 0.14,
        ease: "power3.out",
        scrollTrigger: { trigger: "#services", start: "top 75%" },
      });
    }
  });
</script>
