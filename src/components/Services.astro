---
import SectionHeading from "@/components/SectionHeading.astro";

const items = [
  {
    n: "01",
    title: "WordPress",
    tag: "CMS · Elementor · ACF",
    body: "Custom themes and Elementor builds backed by Advanced Custom Fields. For clients who need to write, edit, and update their own site without calling the developer.",
    bullets: [
      "Custom block libraries",
      "ACF-driven page templates",
      "Migrations & rebuilds",
    ],
  },
  {
    n: "02",
    title: "Astro",
    tag: "Static · Content-driven",
    body: "Lightning-fast marketing sites and portfolios with zero JS by default. Ideal when you want best-in-class performance and SEO without giving up modern DX.",
    bullets: ["Content collections", "View transitions", "Tailwind & MDX"],
  },
  {
    n: "03",
    title: "Next.js",
    tag: "App Router · React · TS",
    body: "Full-stack React apps when the site is also the product. Server components, type-safe APIs, and the rest of the modern stack — without overengineering.",
    bullets: [
      "App Router & RSC",
      "Auth, payments, dashboards",
      "Headless commerce",
    ],
  },
];
---

<section id="services" class="services-section">
  <div class="container">
    <SectionHeading
      index="02"
      eyebrow="Services / The Stack"
      title="Three tools. Picked for the job."
      description="No religion about frameworks — the right one depends on who's editing the site, how it grows, and how often it ships."
    />

    <div class="services-grid">
      {
        items.map((it) => (
          <div class="service-card">
            <div class="card-top">
              <span class="card-num">/ {it.n}</span>
              <span class="label card-tag">{it.tag}</span>
            </div>
            <h3 class="card-title">{it.title}</h3>
            <p class="card-body">{it.body}</p>
            <ul class="card-bullets">
              {it.bullets.map((b) => (
                <li>
                  <span class="bullet-arrow">→</span> {b}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .services-section {
    padding: 8rem 0;
    border-top: 1px solid var(--color-border);
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
  }
  .service-card {
    background: var(--color-card);
    padding: 2.4rem 2rem;
    transition: background 0.25s;
  }
  .service-card:hover {
    background: rgba(255, 255, 255, 0.025);
  }
  .card-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.6rem;
  }
  .card-num {
    font-size: 0.72rem;
    color: var(--color-med-grey);
    letter-spacing: 0.12em;
  }
  .card-tag {
    font-size: 0.66rem;
  }
  .card-title {
    font-size: 1.6rem;
    margin: 0 0 1rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .card-body {
    margin: 0;
    color: var(--color-accent);
    line-height: 1.65;
    font-size: 0.9rem;
  }
  .card-bullets {
    list-style: none;
    padding: 0;
    margin: 1.8rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--color-light-grey);
  }
  .card-bullets li {
    display: flex;
    gap: 0.7rem;
  }
  .bullet-arrow {
    color: var(--color-med-grey);
  }
</style>
