---
import SectionHeading from "@/ui/SectionHeading.astro";

const items = [
  {
    n: "01",
    title: "WordPress",
    tag: "CMS · Elementor · ACF",
    body: "Custom themes and Elementor builds backed by Advanced Custom Fields. For clients who need to write, edit, and update their own site without calling the developer.",
    bullets: [
      "Custom block libraries",
      "ACF-driven page templates",
      "Migrations & rebuilds",
    ],
  },
  {
    n: "02",
    title: "Astro",
    tag: "Static · Content-driven",
    body: "Lightning-fast marketing sites and portfolios with zero JS by default. Ideal when you want best-in-class performance and SEO without giving up modern DX.",
    bullets: ["Content collections", "View transitions", "Tailwind & MDX"],
  },
  {
    n: "03",
    title: "Next.js",
    tag: "App Router · React · TS",
    body: "Full-stack React apps when the site is also the product. Server components, type-safe APIs, and the rest of the modern stack — without overengineering.",
    bullets: [
      "App Router & RSC",
      "Auth, payments, dashboards",
      "Headless commerce",
    ],
  },
];
---

<section id="services" class="border-border border-t py-32">
  <div class="container">
    <SectionHeading
      index="02"
      eyebrow="Services / The Stack"
      title="Tools picked for the job."
      description="No religion about frameworks. Over the years I've reached for whichever tool fit the job."
    />

    <div
      class="bg-border border-border grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-px border"
    >
      {
        items.map((it) => (
          <div class="bg-card px-8 py-[2.4rem] transition-colors duration-200 hover:bg-white/[0.025]">
            <div class="mb-[1.6rem] flex items-baseline justify-between">
              <span class="text-med-grey text-[0.72rem] tracking-[0.12em]">
                / {it.n}
              </span>
              <span class="label text-[0.66rem]">{it.tag}</span>
            </div>
            <h3 class="m-0 mb-4 text-[1.6rem] font-medium tracking-[-0.01em]">
              {it.title}
            </h3>
            <p class="text-accent m-0 text-[0.9rem] leading-[1.65]">
              {it.body}
            </p>
            <ul class="text-light-grey mt-[1.8rem] flex list-none flex-col gap-2 p-0 text-[0.82rem]">
              {it.bullets.map((b) => (
                <li class="flex gap-[0.7rem]">
                  <span class="text-med-grey">→</span> {b}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
