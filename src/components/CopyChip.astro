---
interface Props {
  label: string;
  value: string;
  href: string;
}
const { label, value, href } = Astro.props;
---

<div class="copy-chip">
  <div class="label chip-header">
    <span>{label}</span>
    <button
      type="button"
      class="copy-btn"
      data-copy={value}
      aria-label={`Copy ${label}`}
    >
      <span class="copy-default">COPY</span>
      <span class="copy-done">✓ COPIED</span>
    </button>
  </div>
  <a href={href} class="chip-value">{value}</a>
</div>

<style>
  .copy-chip {
    display: flex;
    flex-direction: column;
    padding: 1.6rem;
    border: 1px solid var(--color-border);
    background: var(--color-card);
    gap: 1rem;
  }
  .chip-header {
    display: flex;
    justify-content: space-between;
  }
  .copy-btn {
    background: none;
    border: none;
    color: var(--color-med-grey);
    letter-spacing: 0.12em;
    font-size: 0.68rem;
    padding: 0;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.2s;
  }
  .copy-btn:hover {
    color: var(--color-light-grey);
  }
  .copy-done {
    display: none;
    color: var(--color-text);
  }
  .copy-btn.copied .copy-default {
    display: none;
  }
  .copy-btn.copied .copy-done {
    display: inline;
  }
  .chip-value {
    font-size: clamp(1.05rem, 2.2vw, 1.4rem);
    color: var(--color-text);
    letter-spacing: -0.01em;
    word-break: break-all;
    transition: color 0.2s;
    text-decoration: none;
  }
  .chip-value:hover {
    color: #e8e8e8;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async (e) => {
      e.preventDefault();
      const v = btn.dataset.copy;
      if (!v) return;
      try {
        await navigator.clipboard.writeText(v);
        btn.classList.add("copied");
        setTimeout(() => btn.classList.remove("copied"), 1600);
      } catch {}
    });
  });
</script>
