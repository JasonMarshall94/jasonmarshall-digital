---
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
---

<section class="container mx-auto grid grid-cols-3 gap-4 pt-24 text-center">
  {
    projects.map((p) => (
      <article>
        <img src={p.data.cover.src} alt={p.data.coverAlt} />
        <h2>{p.data.title}</h2>
        <p>{p.data.excerpt}</p>
      </article>
    ))
  }
</section>
