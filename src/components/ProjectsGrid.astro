---
import { getCollection } from "astro:content";
import SectionHeading from "@/ui/SectionHeading.astro";
import ProjectCard from "@/components/ProjectCard.astro";

interface Props {
  limit?: number;
  showViewAll?: boolean;
}
const { limit, showViewAll = true } = Astro.props;

const allProjects = await getCollection("projects");

const filteredProjects = allProjects
  .filter((p) => !p.data.isDraft && p.data.isFeatured)
  .sort((a, b) => b.data.postDate.valueOf() - a.data.postDate.valueOf());

const displayed = limit ? filteredProjects.slice(0, limit) : filteredProjects;
---

<section id="work" class="border-border border-t py-32">
  <div class="container">
    <SectionHeading
      index="01"
      eyebrow="Work / Selected"
      title="A few recent builds."
      description="A small set of recent client work — mostly small businesses and studios who needed a real website without a real agency."
    />

    <div class="grid grid-cols-[repeat(auto-fit,minmax(320px,1fr))] gap-6">
      {
        displayed.map((p, i) => (
          <ProjectCard project={p} index={i} description={p.data.excerpt} />
        ))
      }
    </div>

    {
      showViewAll && (
        <div class="text-light-grey border-border mt-12 flex flex-wrap items-center justify-between gap-4 border-t border-dashed pt-8 text-[0.82rem]">
          <span>
            Showing {displayed.length} of {allProjects.length} projects
          </span>
          <a href="/projects" class="btn">
            View all projects <span aria-hidden="true">→</span>
          </a>
        </div>
      )
    }
  </div>
</section>
