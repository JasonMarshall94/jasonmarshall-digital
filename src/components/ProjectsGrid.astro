---
import { getCollection } from "astro:content";

const projects = await getCollection(
  "projects",
  ({ data }) => data.isDraft === false,
);
---

<section class="container mx-auto grid grid-cols-3 gap-4 pt-24 text-center">
  {
    projects
      .sort((a, b) => a.data.postDate.valueOf() - b.data.postDate.valueOf())
      .map((p) => (
        <article>
          <img src={p.data.cover.src} alt={p.data.coverAlt} />
          <h2>{p.data.title}</h2>
          <p>{p.data.excerpt}</p>
          <a href={`/projects/${p.data.slug}`}>Read more</a>
        </article>
      ))
  }
</section>
