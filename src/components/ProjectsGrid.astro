---
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
---

<section class="container mx-auto pt-50 text-center">
  {
    projects.map((project) => (
      <div>
        <h2>{project.data.title}</h2>
        <p>{project.data.excerpt}</p>
      </div>
    ))
  }
</section>
