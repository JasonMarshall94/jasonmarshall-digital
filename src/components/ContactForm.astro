---
import data from "@/data/siteData.yaml";

const email: string = data.contactInfo.email;

const fieldClass =
  "w-full bg-transparent border-0 border-b border-border text-text py-3 text-[0.95rem] outline-none transition-colors duration-200 font-[inherit] focus:border-b-text placeholder:text-med-grey";

const labelClass =
  "text-[0.68rem] tracking-[0.18em] uppercase text-light-grey block mb-[0.4rem]";
---

<form
  class="contact-form border-border bg-card flex flex-col gap-[1.6rem] border p-8"
>
  <div class="flex items-center justify-between">
    <div class="label">→ Project Brief</div>
    <div class="text-med-grey text-[0.68rem] tracking-[0.14em]">
      REPLY · WITHIN 24H
    </div>
  </div>

  <div class="grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-[1.4rem]">
    <div>
      <label class={labelClass} for="cf-name">Name</label>
      <input
        id="cf-name"
        name="name"
        type="text"
        placeholder="Your name"
        class={fieldClass}
        required
      />
    </div>
    <div>
      <label class={labelClass} for="cf-email">Email</label>
      <input
        id="cf-email"
        name="email"
        type="email"
        placeholder="you@company.com"
        class={fieldClass}
        required
      />
    </div>
  </div>

  <div class="grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-[1.4rem]">
    <div>
      <p id="type-label" class={labelClass}>Project Type</p>
      <div
        class="chip-group flex flex-wrap gap-2"
        data-group="type"
        role="radiogroup"
        aria-labelledby="type-label"
      >
        {
          ["Website", "SEO", "Not Sure"].map((t, i) => (
            <button
              type="button"
              role="radio"
              aria-checked={i === 0 ? "true" : "false"}
              class={`chip border-border cursor-pointer border px-[0.8rem] py-2 font-[inherit] text-[0.78rem] transition-all duration-200 ${
                i === 0
                  ? "active bg-text text-dark-grey border-text"
                  : "text-accent bg-transparent"
              }`}
              data-value={t}
            >
              {t}
            </button>
          ))
        }
      </div>
      <input type="hidden" name="type" value="Website" data-bind="type" />
    </div>
    <div>
      <p id="budget-label" class={labelClass}>Budget</p>
      <div
        class="chip-group flex flex-wrap gap-2"
        data-group="budget"
        role="radiogroup"
        aria-labelledby="budget-label"
      >
        {
          ["<$5k", "$5-10k", "$10k+", "N/A"].map((t, i) => (
            <button
              type="button"
              role="radio"
              aria-checked={i === 1 ? "true" : "false"}
              class={`chip border-border cursor-pointer border px-[0.8rem] py-2 font-[inherit] text-[0.78rem] transition-all duration-200 ${
                i === 1
                  ? "active bg-text text-dark-grey border-text"
                  : "text-accent bg-transparent"
              }`}
              data-value={t}
            >
              {t}
            </button>
          ))
        }
      </div>
      <input type="hidden" name="budget" value="$5-10k" data-bind="budget" />
    </div>
  </div>

  <div>
    <label class={labelClass} for="cf-msg">Project Details</label>
    <textarea
      id="cf-msg"
      name="message"
      rows="4"
      placeholder="Tell me about your project — timeline, what you're trying to accomplish, any links..."
      class={`${fieldClass} resize-y min-h-30`}
      required></textarea>
  </div>

  <div
    class="cf-turnstile"
    data-sitekey="0x4AAAAAADliDi_ge5DGVkfD"
    data-theme="dark"
    data-appearance="interaction-only"
  >
  </div>

  <div class="flex flex-wrap items-center justify-between gap-4">
    <div
      class="form-status text-med-grey text-[0.74rem] tracking-[0.08em] data-[status=error]:text-[#e08080] data-[status=sent]:text-[#7fc88a]"
      data-status="idle"
      aria-live="polite"
      aria-atomic="true"
    >
      → Replies sent to {email}
    </div>
    <button
      type="submit"
      class="btn btn-primary form-submit disabled:cursor-not-allowed disabled:opacity-60"
    >
      <span class="submit-label">Send Brief</span>
      <span aria-hidden="true">→</span>
    </button>
  </div>
</form>

<script>
  import { actions } from "astro:actions";

  // Lazy-load Turnstile only when the user first interacts with a form
  let turnstileLoaded = false;
  const loadTurnstile = () => {
    if (turnstileLoaded) return;
    turnstileLoaded = true;
    const s = document.createElement("script");
    s.src = "https://challenges.cloudflare.com/turnstile/v0/api.js";
    document.head.appendChild(s);
  };

  document
    .querySelectorAll<HTMLFormElement>(".contact-form")
    .forEach((form) => {
      form.addEventListener("focusin", loadTurnstile, { once: true });
      form.querySelectorAll<HTMLDivElement>(".chip-group").forEach((group) => {
        const selectChip = (target: HTMLButtonElement) => {
          group.querySelectorAll<HTMLButtonElement>(".chip").forEach((c) => {
            c.classList.remove("active", "bg-text", "text-dark-grey", "border-text");
            c.classList.add("bg-transparent", "text-accent");
            c.setAttribute("aria-checked", "false");
          });
          target.classList.remove("bg-transparent", "text-accent");
          target.classList.add("active", "bg-text", "text-dark-grey", "border-text");
          target.setAttribute("aria-checked", "true");
          const groupName = group.dataset.group;
          const hidden = form.querySelector<HTMLInputElement>(`[data-bind="${groupName}"]`);
          if (hidden) hidden.value = target.dataset.value ?? "";
        };

        group.addEventListener("click", (e) => {
          const target = (e.target as HTMLElement).closest<HTMLButtonElement>(".chip");
          if (target) selectChip(target);
        });

        group.addEventListener("keydown", (e) => {
          if (!["ArrowLeft", "ArrowRight", "ArrowUp", "ArrowDown"].includes(e.key)) return;
          e.preventDefault();
          const chips = Array.from(group.querySelectorAll<HTMLButtonElement>(".chip"));
          const current = chips.findIndex((c) => c.getAttribute("aria-checked") === "true");
          const dir = e.key === "ArrowRight" || e.key === "ArrowDown" ? 1 : -1;
          const next = (current + dir + chips.length) % chips.length;
          selectChip(chips[next]);
          chips[next].focus();
        });
      });

      const status = form.querySelector<HTMLDivElement>(".form-status");
      const submit = form.querySelector<HTMLButtonElement>(".form-submit");
      const setStatus = (s: string, msg: string) => {
        if (!status) return;
        status.dataset.status = s;
        status.textContent = msg;
      };

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        if (
          !formData.get("name") ||
          !formData.get("email") ||
          !formData.get("message")
        ) {
          setStatus("error", "× Please fill in name, email, and details.");
          setTimeout(
            () =>
              setStatus(
                "idle",
                "→ Replies sent to contact@jasonmarshall.digital",
              ),
            2200,
          );
          return;
        }
        if (!formData.get("cf-turnstile-response")) {
          setStatus("error", "× Security check not ready — please wait a moment.");
          return;
        }
        setStatus("idle", "→ Sending...");
        if (submit) submit.disabled = true;
        const { error } = await actions.send(formData);
        if (error) {
          setStatus("error", "× Something went wrong. Please email directly.");
        } else {
          setStatus("sent", "✓ Got it — I'll reply within 24 hours.");
          form.reset();
        }
        if (submit) submit.disabled = false;
      });
    });
</script>
