---
import SectionHeading from "@/components/SectionHeading.astro";

const facts = [
  { k: "Based", v: "Philadelphia, PA" },
  { k: "Working", v: "Remote / US" },
  { k: "Experience", v: "10+ years" },
  { k: "Focus", v: "Small business · Studios · Solo founders" },
];

const principles = [
  {
    n: "01",
    title: "Earned the hard way.",
    body: "Ten-plus years inside marketing agencies — hundreds of builds, real deadlines, real clients. That's where the standards on this page come from.",
  },
  {
    n: "02",
    title: "Build for the person editing.",
    body: "If the client can't update the site without breaking it, the build failed. Every project starts with who's going to maintain it.",
  },
  {
    n: "03",
    title: "Performance is a feature.",
    body: "Sub-second loads aren't optional. Static where possible, server-rendered where it matters, JS only when it earns its weight.",
  },
];
---

<section id="about" class="border-border border-t py-32">
  <div class="container">
    <SectionHeading
      index="03"
      eyebrow="About / The Developer"
      title="A decade building for the web."
      description="I'm Jason Marshall — a web developer with 10+ years across marketing agencies and independent client work."
    />

    <div
      class="mb-20 grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-6"
    >
      {
        principles.map((p) => (
          <div class="border-border bg-card border p-8">
            <div class="text-med-grey mb-[1.4rem] text-[0.7rem] tracking-[0.14em]">
              PRINCIPLE / {p.n}
            </div>
            <h4 class="m-0 mb-[0.8rem] text-[1.1rem] leading-[1.3] font-medium tracking-[-0.01em]">
              {p.title}
            </h4>
            <p class="text-accent m-0 text-[0.85rem] leading-[1.65]">
              {p.body}
            </p>
          </div>
        ))
      }
    </div>

    <div
      class="border-border bg-card grid grid-cols-[repeat(auto-fit,minmax(180px,1fr))] border"
    >
      {
        facts.map((f, i) => (
          <div
            class={`px-[1.4rem] py-[1.6rem] ${i < facts.length - 1 ? "border-border border-r" : ""}`}
          >
            <div class="text-med-grey mb-[0.6rem] text-[0.68rem] tracking-[0.18em] uppercase">
              {f.k}
            </div>
            <div class="text-text text-[0.95rem]">{f.v}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>
