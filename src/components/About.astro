---
import SectionHeading from "@/ui/SectionHeading.astro";

const facts = [
  { k: "Based", v: "Philadelphia, PA" },
  { k: "Working", v: "Remote / US" },
  { k: "Experience", v: "10+ years" },
  { k: "Focus", v: "Small businesses · Studios" },
];

const principles = [
  {
    n: "01",
    title: "You get a developer that builds for YOU.",
    body: "Every site I build is designed around your business, your customers, and your goals. You get clean, considered work that is tailored to your business needs.",
  },
  {
    n: "02",
    title: "I've worked with real clients, on real deadlines.",
    body: "Ten-plus years inside marketing agencies means I know how to communicate, hit timelines, and deliver without hand-holding. You won't have to chase me.",
  },
  {
    n: "03",
    title: "The goal is growth, not just a website.",
    body: "A good-looking site that nobody finds is a wasted investment. Design, development, and SEO working together is how small businesses actually get results online.",
  },
];
---

<section id="about" class="border-border border-t py-20 md:py-32">
  <div class="container">
    <SectionHeading
      index="03"
      eyebrow="About / The Developer"
      title="A decade building the web."
      description="I'm Jason Marshall — a web developer with 10+ years across marketing agencies and independent client work."
    />

    <div
      class="mb-20 grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-6"
    >
      {
        principles.map((p) => (
          <div data-principle class="border-border bg-card border p-8">
            <div class="text-med-grey mb-[1.4rem] text-[0.7rem] tracking-[0.14em]">
              PRINCIPLE / {p.n}
            </div>
            <h4 class="m-0 mb-[0.8rem] text-[1.1rem] leading-[1.3] font-medium tracking-[-0.01em]">
              {p.title}
            </h4>
            <p class="text-accent m-0 text-[0.85rem] leading-[1.65]">
              {p.body}
            </p>
          </div>
        ))
      }
    </div>

    <div
      data-facts-bar
      class="border-border bg-card grid grid-cols-[repeat(auto-fit,minmax(180px,1fr))] border"
    >
      {
        facts.map((f, i) => (
          <div
            class={`px-[1.4rem] py-[1.6rem] ${i < facts.length - 1 ? "border-border border-r" : ""}`}
          >
            <div class="text-med-grey mb-[0.6rem] text-[0.68rem] tracking-[0.18em] uppercase">
              {f.k}
            </div>
            <div class="text-text text-[0.95rem]">{f.v}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.matchMedia().add("(prefers-reduced-motion: no-preference)", () => {
    const principles = document.querySelectorAll("[data-principle]");
    if (principles.length) {
      gsap.from(principles, {
        opacity: 0,
        y: 28,
        duration: 0.8,
        stagger: 0.13,
        ease: "power3.out",
        scrollTrigger: { trigger: "#about", start: "top 78%" },
      });
    }

    const factsBar = document.querySelector("[data-facts-bar]");
    if (factsBar) {
      gsap.from(factsBar, {
        opacity: 0,
        y: 20,
        duration: 0.75,
        ease: "power3.out",
        scrollTrigger: { trigger: factsBar, start: "top 88%" },
      });
    }
  });
</script>
