---
interface Props {
  headline?: string;
  description?: string;
  location?: string;
  year?: string;
}
const {
  headline = "Websites that work like they should.",
  description = "Jason Marshall Digital builds fast, maintainable websites for small businesses and studios. WordPress when clients need to edit it, Astro and Next.js when it has to be sharper.",
  location = "Philadelphia, PA",
  year = "2026",
} = Astro.props;
---

<section id="top" class="relative overflow-hidden pt-30 pb-30 md:pt-45">
  <div class="gridlines"></div>
  <div class="relative z-2 container">
    <div
      class="float-in mb-12 flex flex-wrap items-center gap-6"
      style="animation-delay: 0.05s"
    >
      <div
        class="border-border text-light-grey inline-flex items-center gap-[0.6rem] border px-[0.8rem] py-[0.4rem] text-[0.72rem] tracking-[0.12em] uppercase"
      >
        <span class="pulse-dot inline-block h-2 w-2 rounded-full bg-[#7fc88a]"
        ></span>
        Available for new projects · {year}
      </div>
      <div class="label flex items-center gap-2">
        <span>↳ <span id="hero-time">--:--</span> EST</span>
        <span class="text-med-grey">|</span>
        <span>{location}</span>
      </div>
    </div>

    <h1
      class="float-in text-text m-0 text-[clamp(2.4rem,6.6vw,5.6rem)] leading-[1.02] font-medium tracking-[-0.03em] text-balance"
      style="animation-delay: 0.15s"
    >
      {headline}
      <span
        class="blink bg-text ml-[0.1em] inline-block h-[0.9em] w-[0.55em] align-[-0.1em]"
      ></span>
    </h1>

    <div
      class="float-in text-accent mt-10 grid max-w-160 grid-cols-[auto_1fr] gap-x-6 gap-y-4 text-base leading-[1.7]"
      style="animation-delay: 0.3s"
    >
      <span class="text-light-grey select-none">{`>`}</span>
      <p class="m-0">{description}</p>
    </div>

    <div
      class="float-in mt-12 flex flex-wrap gap-4"
      style="animation-delay: 0.45s"
    >
      <a href="#work" class="btn btn-primary">
        View Selected Work <span aria-hidden="true">↓</span>
      </a>
      <a href="#contact" class="btn">
        Start a Project <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>

  <div
    class="text-med-grey absolute right-0 bottom-6 left-0 flex justify-between px-6 text-[0.7rem] tracking-[0.14em] uppercase"
  >
    <span>01 / Index</span>
    <span class="hide-mobile">Jason Marshall Digital · est. 2023</span>
    <span>Scroll ↓</span>
  </div>
</section>

<script>
  const el = document.getElementById("hero-time");
  const tick = () => {
    if (!el) return;
    el.textContent = new Date().toLocaleTimeString("en-US", {
      timeZone: "America/New_York",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
    });
  };
  tick();
  setInterval(tick, 30000);
</script>
