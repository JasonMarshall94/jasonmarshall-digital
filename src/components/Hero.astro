---
interface Props {
  headline?: string;
  description?: string;
  location?: string;
  year?: string;
}
const {
  headline = "Websites that work like they should.",
  description = "Jason Marshall Digital helps small businesses and studios look sharp, rank higher, and grow online. Through thoughtful design, solid development, and SEO that actually moves the needle.",
  location = "Philadelphia, PA",
  year = "2026",
} = Astro.props;
---

<section id="top" class="relative overflow-hidden pt-30 pb-30 md:pt-45">
  <div class="gridlines"></div>
  <div class="relative z-2 container">
    <div
      data-hero="badge"
      class="mb-12 flex flex-wrap items-center gap-6"
      style="opacity: 0; transform: translateY(16px)"
    >
      <div
        class="border-border text-light-grey inline-flex items-center gap-[0.6rem] border px-[0.8rem] py-[0.4rem] text-[0.72rem] tracking-[0.12em] uppercase"
      >
        <p>
          <span class="pulse-dot inline-block h-2 w-2 rounded-full bg-[#7fc88a]"
          ></span>
          Available for new projects · {year}
        </p>
      </div>
      <div class="label flex items-center gap-2">
        <span>↳ <span id="hero-time">--:--</span> EST</span>
        <span class="text-med-grey">|</span>
        <span>{location}</span>
      </div>
    </div>

    <h1
      data-hero="headline"
      class="text-text m-0 text-[clamp(2.4rem,6.6vw,5.6rem)] leading-[1.02] font-medium tracking-[-0.03em] text-balance"
      style="opacity: 0"
    >
      {headline}
      <span
        class="blink bg-text ml-[0.1em] inline-block h-[0.9em] w-[0.55em] align-[-0.1em]"
      ></span>
    </h1>

    <div
      data-hero="desc"
      class="text-accent mt-10 grid max-w-160 grid-cols-[auto_1fr] gap-x-6 gap-y-4 text-base leading-[1.7]"
      style="opacity: 0; transform: translateY(16px)"
    >
      <span class="text-light-grey select-none">{`>`}</span>
      <p class="m-0">{description}</p>
    </div>

    <div
      data-hero="cta"
      class="mt-12 flex flex-wrap gap-4"
      style="opacity: 0; transform: translateY(16px)"
    >
      <a href="#work" class="btn btn-primary">
        View Selected Work <span aria-hidden="true">↓</span>
      </a>
      <a href="#contact" class="btn">
        Start a Project <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>

  <div
    class="text-med-grey absolute right-0 bottom-6 left-0 flex justify-between px-6 text-[0.7rem] tracking-[0.14em] uppercase"
  >
    <span>01 / Index</span>
    <span class="hide-mobile">Jason Marshall Digital · est. 2023</span>
    <span>Scroll ↓</span>
  </div>
</section>

<script>
  const el = document.getElementById("hero-time");
  const tick = () => {
    if (!el) return;
    el.textContent = new Date().toLocaleTimeString("en-US", {
      timeZone: "America/New_York",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
    });
  };
  tick();
  setInterval(tick, 30000);
</script>

<script>
  import { gsap } from "gsap";
  import { SplitText } from "gsap/SplitText";
  gsap.registerPlugin(SplitText);

  const mm = gsap.matchMedia();

  mm.add("(prefers-reduced-motion: no-preference)", () => {
    const badge = document.querySelector('[data-hero="badge"]');
    const headline = document.querySelector('[data-hero="headline"]');
    const desc = document.querySelector('[data-hero="desc"]');
    const cta = document.querySelector('[data-hero="cta"]');

    const tl = gsap.timeline({ delay: 0.15 });

    if (badge) {
      tl.to(badge, { opacity: 1, y: 0, duration: 0.7, ease: "power3.out" });
    }

    if (headline) {
      const cursor = headline.querySelector(".blink");
      const split = new SplitText(headline, { type: "chars,words" });
      gsap.set(split.chars, { opacity: 0 });
      gsap.set(headline, { opacity: 1 });
      if (cursor) gsap.set(cursor, { opacity: 0 });
      tl.to(
        split.chars,
        {
          opacity: 1,
          duration: 0,
          stagger: 0.028,
          ease: "none",
          onComplete: () => cursor && gsap.set(cursor, { opacity: 1 }),
        },
        "<0.2",
      );
    }

    if (desc) {
      tl.to(
        desc,
        { opacity: 1, y: 0, duration: 0.75, ease: "power3.out" },
        "-=0.7",
      );
    }

    if (cta) {
      tl.to(
        cta,
        { opacity: 1, y: 0, duration: 0.75, ease: "power3.out" },
        "<0.3",
      );
    }
  });

  mm.add("(prefers-reduced-motion: reduce)", () => {
    gsap.set(
      [
        '[data-hero="badge"]',
        '[data-hero="headline"]',
        '[data-hero="desc"]',
        '[data-hero="cta"]',
      ],
      { opacity: 1, clearProps: "transform" },
    );
  });
</script>
