---
import Logo from "@/components/Logo.astro";

const links = [
  { title: "Work", slug: "work" },
  { title: "Services", slug: "services" },
  { title: "About", slug: "about" },
  { title: "Contact", slug: "contact" },
];
---

<header id="site-nav">
  <div class="nav-inner container">
    <a href="#top" class="brand">
      <Logo size={28} />
      <span class="brand-label hide-mobile">Jason Marshall Digital</span>
    </a>

    <nav class="nav-links">
      {
        links.map((l) => (
          <a
            href={`#${l.slug}`}
            class="nav-link hide-mobile nav-anchor"
            data-section={l.slug}
          >
            {l.title}
          </a>
        ))
      }
      <a
        href="https://github.com/JasonMarshall94"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="gh-link"
      >
        <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor">
          <path
            d="M10,0 C4.477,0 0,4.59 0,10.253 C0,14.782 2.862,18.624 6.833,19.981 C7.34,20.082 7.52,19.762 7.52,19.489 C7.52,19.151 7.508,18.047 7.508,16.675 C7.508,15.719 7.828,15.095 8.187,14.777 C5.96,14.523 3.62,13.656 3.62,9.718 C3.62,8.598 4.008,7.684 4.65,6.966 C4.546,6.707 4.203,5.664 4.748,4.252 C4.748,4.252 5.586,3.977 7.495,5.303 C8.294,5.076 9.15,4.962 10,4.958 C10.85,4.962 11.705,5.076 12.503,5.303 C14.414,3.977 15.254,4.252 15.254,4.252 C15.797,5.664 15.454,6.707 15.351,6.966 C15.99,7.684 16.381,8.598 16.381,9.718 C16.381,13.646 14.046,14.526 11.825,14.785 C12.111,15.041 12.37,15.493 12.46,16.156 C13.03,16.418 14.478,16.871 15.37,15.304 C15.37,15.304 15.899,14.319 16.903,14.247 C16.903,14.247 17.878,14.234 16.971,14.87 C16.971,14.87 16.316,15.185 15.861,16.37 C15.861,16.37 15.274,18.2 12.492,17.58 C12.487,18.437 12.478,19.245 12.478,19.489 C12.478,19.76 12.662,20.077 13.161,19.982 C17.135,18.627 20,14.783 20,10.253 C20,4.59 15.522,0 10,0"
          ></path>
        </svg>
      </a>
    </nav>
  </div>
</header>

<style>
  #site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: rgba(18, 18, 18, 0);
    border-bottom: 1px solid transparent;
    transition:
      background 0.25s,
      border-color 0.25s;
  }
  #site-nav.scrolled {
    background: rgba(18, 18, 18, 0.78);
    border-bottom-color: var(--color-border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-text);
  }
  .brand-label {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-light-grey);
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    font-size: 0.82rem;
  }
  .nav-anchor {
    color: var(--color-light-grey);
    letter-spacing: 0.06em;
    transition: color 0.2s;
  }
  .nav-anchor.active {
    color: var(--color-text);
  }
  .gh-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--color-border);
    color: var(--color-light-grey);
    transition: all 0.2s;
  }
  .gh-link:hover {
    color: var(--color-text);
    border-color: var(--color-light-grey);
  }
</style>

<script>
  // Sticky-blur on scroll + active-section scroll spy
  const nav = document.getElementById("site-nav");
  const sectionIds = ["top", "work", "services", "about", "contact"];
  const anchors = Array.from(
    document.querySelectorAll<HTMLAnchorElement>(".nav-anchor"),
  );

  const onScroll = () => {
    if (!nav) return;
    nav.classList.toggle("scrolled", window.scrollY > 24);

    const y = window.scrollY + window.innerHeight / 3;
    let current = "top";
    for (const id of sectionIds) {
      const el = document.getElementById(id);
      if (el && el.offsetTop <= y) current = id;
    }
    anchors.forEach((a) => {
      a.classList.toggle("active", a.dataset.section === current);
    });
  };

  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();
</script>
