---
interface Props {
  index: string;
  eyebrow: string;
  title: string;
  description?: string;
}
const { index, eyebrow, title, description } = Astro.props;
---

<div
  data-sh
  class="border-border mb-12 grid grid-cols-[minmax(0,1fr)_minmax(0,2fr)] items-end gap-12 border-b pb-12 max-[860px]:grid-cols-1 max-[860px]:gap-6"
>
  <div>
    <div class="label flex items-center gap-[0.6rem]">
      <span class="text-med-grey">{index}</span>
      <span>{eyebrow}</span>
    </div>
  </div>
  <div>
    <h2
      class="text-text m-0 text-[clamp(1.6rem,3.4vw,2.8rem)] leading-[1.1] font-medium tracking-[-0.02em]"
    >
      {title}
    </h2>
    {
      description && (
        <p class="text-accent mt-4 mb-0 max-w-140 text-[0.95rem] leading-[1.6]">
          {description}
        </p>
      )
    }
  </div>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.matchMedia().add("(prefers-reduced-motion: no-preference)", () => {
    document.querySelectorAll("[data-sh]").forEach((el) => {
      const targets = [
        el.querySelector(".label"),
        el.querySelector("h2"),
        el.querySelector("p"),
      ].filter(Boolean);
      gsap.from(targets, {
        opacity: 0,
        y: 18,
        duration: 0.8,
        stagger: 0.12,
        ease: "power3.out",
        scrollTrigger: { trigger: el, start: "top 84%" },
      });
    });
  });
</script>
