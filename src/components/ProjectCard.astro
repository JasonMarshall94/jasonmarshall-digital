---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
  index: number;
  description?: string;
  loading?: "lazy" | "eager";
}
const { project, index, description, loading = "lazy" } = Astro.props;
const { data } = project;
const num = String(index + 1).padStart(2, "0");
const year = data.postDate.getFullYear();
---

<a
  href={data.url ?? "#"}
  target={data.url ? "_blank" : undefined}
  rel={data.url ? "noopener noreferrer" : undefined}
  class="project-card group border-border bg-card text-text relative block border no-underline"
>
  <div
    class="project-image bg-deep border-border relative aspect-video overflow-hidden border-b [&_img]:block [&_img]:h-full [&_img]:w-full [&_img]:object-cover"
  >
    <Image
      src={data.cover}
      alt={data.coverAlt}
      widths={[600, 900, 1200]}
      sizes="(max-width: 720px) 100vw, 33vw"
      loading={loading}
    />
    <div
      class="pointer-events-none absolute inset-0 bg-[linear-gradient(180deg,rgba(18,18,18,0)_60%,rgba(18,18,18,0.7)_100%)]"
    >
    </div>
    <div
      class="text-text absolute top-4 left-4 bg-black/50 px-[0.6rem] py-[0.3rem] text-[0.72rem] tracking-[0.12em] backdrop-blur-xs"
    >
      / {num}
    </div>
  </div>

  <div class="px-[1.6rem] pt-[1.6rem] pb-[1.8rem]">
    <div class="mb-[0.8rem] flex justify-between gap-4">
      <h3 class="text-text m-0 text-[1.25rem] font-medium tracking-[-0.01em]">
        {data.title}
      </h3>
      <span class="text-light-grey shrink-0 text-[0.78rem]">{year}</span>
    </div>
    <p class="text-accent m-0 mb-[1.2rem] text-[0.85rem] leading-[1.6]">
      {description ?? data.excerpt}
    </p>
    <div
      class="border-border flex items-center justify-between gap-4 border-t pt-4"
    >
      <div
        class="text-light-grey flex flex-wrap gap-2 text-[0.7rem] tracking-[0.06em]"
      >
        {
          data.tags.map((t, i) => (
            <span>
              {t}
              {i < data.tags.length - 1 && (
                <span class="text-med-grey ml-2">/</span>
              )}
            </span>
          ))
        }
      </div>
      <span
        class="text-light-grey group-hover:text-text inline-flex items-center gap-[0.4rem] text-[0.75rem] tracking-[0.08em] uppercase transition-colors duration-200"
      >
        Visit
        <span
          class="inline-block transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
        >
          ↗
        </span>
      </span>
    </div>
  </div>
</a>
