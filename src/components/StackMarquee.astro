---
import stackItems from "@/data/stackItems.ts";

interface Props {
  items?: string[];
}
const { items = stackItems } = Astro.props;
---

<div
  class="scroll-fade-mask border-border overflow-hidden border-y bg-white/[0.01] py-[1.4rem]"
>
  <div class="marquee">
    {
      [0, 1].map(() => (
        <div class="text-light-grey flex gap-16 pr-16 text-[0.85rem] tracking-[0.18em] uppercase">
          {items.map((t) => (
            <span class="flex items-center gap-16">
              {t}
              <span class="text-med-grey">✦</span>
            </span>
          ))}
        </div>
      ))
    }
  </div>
</div>
