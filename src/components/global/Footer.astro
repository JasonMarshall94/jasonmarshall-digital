---
import Logo from "@/global/Logo.astro";

interface Props {
  startYear?: number;
  githubUrl?: string;
}
const { startYear = 2016, githubUrl = "https://github.com/JasonMarshall94" } =
  Astro.props;
const currentYear = new Date().getFullYear();
const ghLabel = githubUrl.replace(/^https?:\/\//, "");
---

<footer class="border-border mt-8 border-t pt-12 pb-8">
  <div class="container">
    <div
      data-footer-cta
      class="border-border mb-6 grid grid-cols-[auto_1fr_auto] items-center gap-8 border-b pb-10 max-[720px]:grid-cols-1 max-[720px]:justify-items-center max-[720px]:text-center"
    >
      <a
        href="#top"
        class="text-text flex items-center gap-[0.8rem]"
        aria-label="Return to top"
      >
        <Logo size={36} />
      </a>
      <div
        class="text-text text-[clamp(1.2rem,2.4vw,1.8rem)] leading-[1.2] tracking-[-0.01em]"
      >
        Building on the web since {startYear}.<br />
        <span class="text-light-grey">Always open to interesting work.</span>
      </div>
      <a href="/#contact" class="btn">Get in touch →</a>
    </div>

    <div
      class="text-med-grey flex flex-wrap items-center justify-between gap-4 text-[0.74rem] tracking-widest max-[720px]:justify-center max-[720px]:text-center"
    >
      <span>© {currentYear} Jason Marshall Digital · All rights reserved</span>
      <span class="hide-mobile">Built with Astro &amp; Tailwind</span>
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="nav-link text-light-grey"
      >
        {ghLabel} ↗
      </a>
    </div>
  </div>
</footer>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.matchMedia().add("(prefers-reduced-motion: no-preference)", () => {
    const cta = document.querySelector("[data-footer-cta]");
    if (cta) {
      gsap.from(cta, {
        opacity: 0,
        y: 24,
        duration: 0.85,
        ease: "power3.out",
        scrollTrigger: { trigger: cta, start: "top 90%" },
      });
    }
  });
</script>
