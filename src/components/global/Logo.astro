---
interface Props {
  size?: number;
  class?: string;
}
const { size = 28, class: className = "" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 200 200"
  fill="none"
  width={size}
  height={size}
  class={className}
  aria-label="Jason Marshall Digital"
>
  <circle cx="100" cy="100" r="90" fill="none" stroke="#e0e0e0" stroke-width="7"
  ></circle>
  <g
    fill="none"
    stroke="#e0e0e0"
    stroke-width="11"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M84 65 L84 115 Q84 135 63 135 Q47 135 47 116"></path>
    <path d="M113 135 L113 65 L132 106 L151 65 L151 135"></path>
  </g>
</svg>
